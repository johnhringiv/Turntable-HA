# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly set common text file types to use LF
*.py     text eol=lf
*.sh     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.json   text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.Dockerfile text eol=lf
